# ============================================
# ASSFAC - Sistema Financeiro Integrado
# Arquivo de exemplo de variáveis de ambiente
# ============================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (ou .env.local)
# 2. Preencha os valores com suas credenciais reais
# 3. NUNCA commite o arquivo .env no Git (já está no .gitignore)
#
# ============================================

# ============================================
# SUPABASE - Configuração do Banco de Dados
# ============================================
# 
# Como obter essas credenciais:
# 1. Acesse: https://app.supabase.com
# 2. Selecione seu projeto
# 3. Vá em Settings → API
# 4. Copie:
#    - Project URL → VITE_SUPABASE_URL
#    - anon/public key → VITE_SUPABASE_PUBLISHABLE_KEY
#
# ⚠️ IMPORTANTE: Use APENAS a chave anon/public (NUNCA a service_role no frontend!)

# URL do projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
# Em build de produção (ou se definir true abaixo), o browser usa /supabase no mesmo domínio da app
# (rewrite no vercel.json). Mantenha sempre a URL .supabase.co em VITE_SUPABASE_URL.
# VITE_SUPABASE_USE_SAME_ORIGIN_PROXY=true

# Chave pública/anônima do Supabase (anon/public key)
VITE_SUPABASE_PUBLISHABLE_KEY=sua_chave_anon_public_aqui

# ============================================
# SUPABASE - Next.js (opcional, para migração futura)
# ============================================
# Se você estiver usando Next.js, use essas variáveis em vez das VITE_*
# NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_chave_anon_public_aqui

# ============================================
# AMBIENTE
# ============================================
# development | test | production
NODE_ENV=development

# ============================================
# N8N - Integração DISECURIT (Fase 1)
# ============================================
# URL do webhook n8n para import inicial
N8N_DISECURIT_IMPORT_WEBHOOK_URL=https://seu-n8n.exemplo.com/webhook/disecurit/import

# URL do webhook n8n para reprocesso (pode ser a mesma do import)
N8N_DISECURIT_REPROCESS_WEBHOOK_URL=https://seu-n8n.exemplo.com/webhook/disecurit/import

# Segredo compartilhado entre Vercel API e n8n (header x-integration-secret)
N8N_DISECURIT_INTEGRATION_SECRET=seu_segredo_forte_aqui

# ============================================
# N8N - Assistente Operações com IA (copiloto)
# ============================================
# Webhook do workflow "Operações IA - Assistente Copiloto" (ex.: /webhook/operacoes-ia/chat).
# Se ausentes, api_legacy/operacoes-ia/message.ts responde com texto estático (fallback).
# Produção: também configure na Vercel (ou use scripts/set-vercel-operacoes-ia-env.cjs).
# No n8n, defina N8N_OPERACOES_IA_INTEGRATION_SECRET com o mesmo valor.
N8N_OPERACOES_IA_WEBHOOK_URL=https://seu-n8n.exemplo.com/webhook/operacoes-ia/chat
N8N_OPERACOES_IA_INTEGRATION_SECRET=seu_segredo_operacoes_ia_aqui

# Opcional no n8n: serviço externo para extração de texto de PDF
# PDF_TEXT_SERVICE_URL=https://seu-servico-pdf-text.exemplo.com/extract

# ============================================
# NOTAS IMPORTANTES
# ============================================
#
# 1. SEGURANÇA:
#    - NUNCA commite o arquivo .env no Git
#    - NUNCA compartilhe suas chaves em público
#    - Use chaves diferentes para desenvolvimento e produção
#
# 2. DEPLOY:
#    - Para Vercel: Configure as variáveis no Dashboard
#    - Para outros serviços: Configure nas variáveis de ambiente
#
# 3. VALIDAÇÃO:
#    - O sistema valida automaticamente essas variáveis no boot
#    - Se faltar alguma variável obrigatória, a aplicação não iniciará
#
# ============================================

# Feature flag: habilita edicao de transferencias via RPC transacional no Supabase.
VITE_ENABLE_TRANSFERENCIA_EDIT_RPC=true
